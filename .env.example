# ==========================================
# VMS PROJECT ENVIRONMENT CONFIGURATION
# Copy this file to .env and fill in values
# ==========================================

# --- Django Settings ---
# Set to 'prod' or 'production' on Ubuntu server
DJANGO_ENV=prod
DJANGO_SECRET_KEY=your_secure_random_secret_key_here
# Comma-separated list of allowed hosts, e.g., your_domain.com,your_ip
ALLOWED_HOSTS=127.0.0.1,localhost
# Comma-separated list of trusted origins, e.g., https://your_domain.com
CSRF_TRUSTED_ORIGINS=https://your_domain.com
PLATFORM_DOMAIN=vistron.zaryz.in
ADMIN_EMAIL=admin@example.com

# --- PostgreSQL Database Settings ---
# Used by Django to connect
DB_ENGINE=django.db.backends.postgresql
DB_NAME=vistron_db
DB_USER=vistron_user
DB_PASSWORD=vistron_secure_password
DB_HOST=db
DB_PORT=5432

# Used by PostgreSQL Docker container to initialize
POSTGRES_DB=vistron_db
POSTGRES_USER=vistron_user
POSTGRES_PASSWORD=vistron_secure_password

# --- Redis Settings ---
REDIS_HOST=redis
REDIS_PORT=6379

# --- System Email Settings ---
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your_email@gmail.com
EMAIL_HOST_PASSWORD=your_app_password
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
DEFAULT_FROM_EMAIL=your_email@gmail.com

# --- Contact Form Email Settings ---
CONTACT_EMAIL_HOST=smtp.office365.com
CONTACT_EMAIL_PORT=587
CONTACT_EMAIL_HOST_USER=connect@zaryz.com
CONTACT_EMAIL_HOST_PASSWORD=your_contact_email_password
CONTACT_EMAIL_USE_TLS=True
CONTACT_EMAIL_RECEIVER=vms@zaryz.com
