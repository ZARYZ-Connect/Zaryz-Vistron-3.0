# ==========================================
# VISTRON VMS — PRODUCTION .env
# Copy this to .env on the Ubuntu server
# NEVER commit .env to Git
# ==========================================

# --- Django Environment ---
# 'prod' disables DEBUG mode (critical for production!)
DJANGO_ENV=prod

# Generate a strong secret key:
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=REPLACE_WITH_YOUR_STRONG_SECRET_KEY

# --- Allowed Hosts ---
# Include your platform domain + wildcard for all tenant subdomains
# Django supports leading dot (.) as wildcard for subdomains
ALLOWED_HOSTS=vistron.zaryz.in,.zaryz.in,localhost,127.0.0.1

# --- CSRF Trusted Origins ---
# Must include ALL origins that send POST requests (including all tenant subdomains)
CSRF_TRUSTED_ORIGINS=https://vistron.zaryz.in,https://*.zaryz.in

# --- Platform Domain ---
PLATFORM_DOMAIN=vistron.zaryz.in

# --- Admin Email ---
ADMIN_EMAIL=admin@zaryz.com

# --- PostgreSQL Database Settings ---
# (DB_HOST must be 'db' — the Docker service name)
DB_ENGINE=django.db.backends.postgresql
DB_NAME=vistron_db
DB_USER=vistron_user
DB_PASSWORD=REPLACE_WITH_STRONG_DB_PASSWORD
DB_HOST=db
DB_PORT=5432

# --- PostgreSQL Docker Container Init ---
# (These must match the DB_* values above)
POSTGRES_DB=vistron_db
POSTGRES_USER=vistron_user
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_DB_PASSWORD

# --- Redis Settings ---
# (REDIS_HOST must be 'redis' — the Docker service name)
REDIS_HOST=redis
REDIS_PORT=6379

# --- System Email (for visitor notifications, approvals, etc.) ---
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your_email@gmail.com
EMAIL_HOST_PASSWORD=your_gmail_app_password
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
DEFAULT_FROM_EMAIL=VMS Vistron <your_email@gmail.com>

# --- Contact Form Email (landing page only) ---
CONTACT_EMAIL_HOST=smtp.office365.com
CONTACT_EMAIL_PORT=587
CONTACT_EMAIL_HOST_USER=connect@zaryz.com
CONTACT_EMAIL_HOST_PASSWORD=REPLACE_WITH_CONTACT_EMAIL_PASSWORD
CONTACT_EMAIL_USE_TLS=True
CONTACT_EMAIL_RECEIVER=vms@zaryz.com
